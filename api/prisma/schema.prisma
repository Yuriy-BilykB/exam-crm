generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum Role {
  admin
  manager
}

enum TokenType {
  activate
  recovery
}

model User {
  id        String   @id @default(cuid())

  email     String   @unique @db.VarChar(100)
  password  String?  @db.VarChar(255)
  name      String?  @db.VarChar(50)
  surname   String?  @db.VarChar(50)
  role      Role     @default(manager)
  isActive  Boolean  @default(false) @map("is_active")
  isBanned  Boolean  @default(false) @map("is_banned")

  orders           Order[]
  comments         Comment[]
  activationTokens ActivationToken[]

  createdAt DateTime  @default(now()) @map("created_at")
  lastLogin DateTime? @map("last_login")

  @@map("users")
}

model Order {
  id           Int      @id @default(autoincrement())

  name         String?  @db.VarChar(100)
  surname      String?  @db.VarChar(100)
  email        String?  @db.VarChar(150)
  phone        String?  @db.VarChar(40)
  age          Int?

  course       String?  @db.VarChar(30)
  courseFormat String?  @map("course_format") @db.VarChar(30)
  courseType   String?  @map("course_type") @db.VarChar(100)

  status       String?  @db.VarChar(40)
  sum          Int?
  alreadyPaid  Int?     @map("alreadyPaid")
  utm          String?  @db.VarChar(255)
  message      String?  @map("msg") @db.VarChar(255)

  manager   User?   @relation(fields: [managerId], references: [id], onDelete: SetNull)
  managerId String? @map("manager_id")

  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  groupId String? @map("group_id")

  comments Comment[]

  createdAt DateTime? @default(now()) @map("created_at")

  @@index([managerId])
  @@index([groupId])
  @@index([status])
  @@map("orders")
}

model Comment {
  id            String   @id @default(cuid())
  text          String   @db.Text

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId Int   @map("order_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderId])
  @@index([userId])
  @@map("comments")
}

model Group {
  id        String   @id @default(cuid())
  name      String   @unique @db.VarChar(100)

  orders    Order[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("groups")
}

model ActivationToken {
  id        String    @id @default(cuid())
  token     String    @db.VarChar(512)
  type      TokenType
  expiresAt DateTime  @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @map("user_id")

  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("activation_tokens")
}
