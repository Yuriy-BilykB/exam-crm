{
  "info": {
    "name": "CRM Programming School API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "access_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) pm.collectionVariables.set('access_token', json.access_token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@gmail.com\",\n  \"password\": \"admin\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Set password (activate/recovery)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<token from link>\",\n  \"password\": \"newPassword123\"\n}" },
            "url": "{{baseUrl}}/auth/set-password"
          }
        }
      ]
    },
    {
      "name": "Reference",
      "item": [
        { "name": "Courses", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{baseUrl}}/courses" } },
        { "name": "Course formats", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{baseUrl}}/course-formats" } },
        { "name": "Course types", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{baseUrl}}/course-types" } },
        { "name": "Statuses", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{baseUrl}}/statuses" } },
        { "name": "Groups", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }], "url": "{{baseUrl}}/groups" } },
        { "name": "Create group", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\"name\": \"Group 1\"}" }, "url": "{{baseUrl}}/groups" } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/orders?page=1&limit=25&sortBy=created_at&sortOrder=DESC"
          }
        },
        {
          "name": "List orders (my only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/orders?my_orders=true&page=1&limit=25"
          }
        },
        {
          "name": "Get order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/orders/1"
          }
        },
        {
          "name": "Update order",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status_id\": 2,\n  \"group_id\": 1\n}" },
            "url": "{{baseUrl}}/orders/1"
          }
        },
        {
          "name": "Export Excel",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/orders/export?page=1&limit=100"
          }
        },
        {
          "name": "Get comments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/orders/1/comments"
          }
        },
        {
          "name": "Add comment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"comment\": \"First contact\"}" },
            "url": "{{baseUrl}}/orders/1/comments"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Create manager",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"manager@example.com\",\n  \"name\": \"John\"\n}" },
            "url": "{{baseUrl}}/admin/managers"
          }
        },
        {
          "name": "List managers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/admin/managers?page=1&limit=25"
          }
        },
        {
          "name": "Stats by status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/admin/stats"
          }
        },
        {
          "name": "Manager stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/admin/managers/2/stats"
          }
        },
        {
          "name": "Activate manager (get link)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/admin/managers/2/activate"
          }
        },
        {
          "name": "Recovery password (get link)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/admin/managers/2/recovery"
          }
        },
        {
          "name": "Ban user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/admin/managers/2/ban"
          }
        },
        {
          "name": "Unban user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{baseUrl}}/admin/managers/2/unban"
          }
        }
      ]
    }
  ]
}
