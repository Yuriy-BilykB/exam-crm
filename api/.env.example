# Database (MySQL) - ТЗ: http://owu.linkpc.net/mysql
# Prisma connection string. Matches the docker-compose MySQL service.
DATABASE_URL="mysql://root:root@localhost:3306/crm_db"

# JWT
JWT_SECRET=your-secret-change-in-production
# Separate secret for refresh tokens (stored in httpOnly cookie)
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# Frontend URL (for CORS and activation links)
FRONTEND_URL=http://localhost:3000

# Port
PORT=5000

# Node
NODE_ENV=development

# SMTP (activation/recovery emails). If SMTP_HOST is empty, email sending is
# skipped and the admin just copies the link manually.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CRM <no-reply@crm.local>"
